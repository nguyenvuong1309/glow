{
  "name": "Glow",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "start": "react-native start",
    "test": "jest",
    "android:dev": "react-native run-android --mode devDebug --appIdSuffix dev",
    "android:prod": "APP_ENV=production react-native run-android --mode prodRelease",
    "ios:dev": "react-native run-ios",
    "ios:prod": "APP_ENV=production react-native run-ios --mode Release",
    "appium": "appium",
    "e2e": "wdio run wdio.conf.ts",
    "e2e:spec": "wdio run wdio.conf.ts --spec",
    "e2e:single": "wdio run wdio.single.conf.ts",
    "e2e:single:spec": "wdio run wdio.single.conf.ts --spec",
    "prepare": "husky"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/app-distribution": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "@react-navigation/stack": "^7.8.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.98.0",
    "i18next": "^25.8.13",
    "lottie-ios": "4.6.0",
    "lottie-react-native": "^7.3.6",
    "react": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-native": "0.84.1",
    "react-native-calendars": "^1.1314.0",
    "react-native-date-picker": "5.0.13",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-image-viewing": "^0.2.2",
    "react-native-localize": "^3.7.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-purchases": "^9.14.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@bam.tech/react-native-make": "^3.0.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "appium": "^3.2.2",
    "appium-xcuitest-driver": "^10.32.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": true
    }
  }
}
